{
  "name": "electron-bench",
  "version": "1.0.0",
  "description": "An Electron app to perform a few benchmarks.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "bench:run": "electron . --bench-output=bench-results/latest.json",
    "bench:update-docs": "node scripts/update-best-practices.js --input bench-results/latest.json",
    "bench:refresh-docs": "npm run bench:run && npm run bench:update-docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZacWalk/electron-bench.git"
  },
  "author": "Zac Walker",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ZacWalk/electron-bench/issues"
  },
  "homepage": "https://github.com/ZacWalk/electron-bench#readme",
  "devDependencies": {
    "electron": "^41.1.0",
    "percentile": "1.2.1"
  }
}
